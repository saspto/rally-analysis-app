# ── Rally Configuration ───────────────────────────────────────────────────────
# Obtain from Rally > My Profile > API Keys
RALLY_API_KEY=your_rally_zsessionid_api_key_here

# Your Rally workspace name (exactly as shown in Rally)
RALLY_WORKSPACE=your_workspace_name_here

# ── AWS Configuration ─────────────────────────────────────────────────────────
# S3 bucket created by the SAM stack (auto-populated by deploy.sh)
EXPORT_BUCKET=rally-exports-dev-123456789012
AWS_REGION=us-east-1

# ── Anthropic (Claude) Configuration ─────────────────────────────────────────
# Obtain from https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Frontend (Vite) Configuration ─────────────────────────────────────────────
# API Gateway URL (auto-populated by deploy.sh after deployment)
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev

# Set to "true" to use mock data without a live backend
VITE_USE_MOCK=true
